          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عملية شراء واحدة لمرة واحدة تفتح كل مستحضرات التجميل الحالية وكل مستحضرات التجميل في المستقبل التي نقوم بشحنها تلقائيا."
          }
        },
