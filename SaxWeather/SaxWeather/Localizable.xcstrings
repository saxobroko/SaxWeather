        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Corner radius and inner padding. Original WeatherDetailsView used 24 pt radius, 16 pt horizontal padding, 20 pt vertical padding."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Raggio angolare e imbottitura interna. MeteoDettagli originaliVista utilizzata raggio 24 pt, imbottitura orizzontale 16 pt, imbottitura verticale 20 pt."
          }
        },
        "ja" : {
          "stringUnit" : {
