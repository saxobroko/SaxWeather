    "Custom locations are currently ignored because a Weather Underground station is configured. Disable API keys in Settings → Locations to use saved locations." : {
      "comment" : "Warning about Weather Underground overriding saved locations.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Custom locations are currently ignored because a Weather Underground station is configured. Disable API keys in Settings → Locations to use saved locations."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Custom locations are currently ignored because a Weather Underground station is configured. Disable API keys in Settings → Locations to use saved locations."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتم حاليا تجاهل المواقع المخصصة بسبب تكوين محطة الطقس تحت الأرض. تعطيل مفاتيح API في الإعدادات > المواقع لاستخدام المواقع المحفوظة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Custom locations are currently ignored because a Weather Underground station is configured. Disable API keys in Settings → Locations to use saved locations."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vlastní umístění jsou nyní ignorována, protože je nastavena stanice meteometru. Zakažte API klíče v Nastavení → Místa pro použití uložených umístění."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brugerdefinerede placeringer ignoreres i øjeblikket, fordi en Weather Underground station er konfigureret. Deaktivér API-nøgler i Indstillinger → Placeringer for at bruge gemte placeringer."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benutzerdefinierte Standorte werden derzeit ignoriert, da eine Wetteruntergrundstation konfiguriert ist. Deaktivieren Sie API-Tasten in Einstellungen → Standorte, um gespeicherte Orte zu verwenden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι προσαρμοσμένες τοποθεσίες αγνοούνται επί του παρόντος επειδή έχει ρυθμιστεί ένας σταθμός Μετεωρολογικού υπόγειου. Απενεργοποιήστε τα κλειδιά API στις Ρυθμίσεις → Τοποθεσίες για να χρησιμοποιήσετε τις αποθηκευμένες τοποθεσίες."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las ubicaciones personalizadas están actualmente ignoradas porque se ha configurado una estación Meteorológica Subterránea. Deshabilita las claves API en Ajustes → Ubicaciones para usar ubicaciones guardadas."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mukautetut sijainnit ohitetaan tällä hetkellä, koska Weather Underground asema on määritetty. Poista API-avaimet käytöstä Asetukset → Sijainnit käyttääksesi tallennettuja sijainteja."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les emplacements personnalisés sont actuellement ignorés car une station Weather Underground est configurée. Désactivez les clés API dans Paramètres → Emplacements pour utiliser les emplacements enregistrés."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Custom locations are currently ignored because a Weather Underground station is configured. Disable API keys in Settings → Locations to use saved locations."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Custom locations are currently ignored because a Weather Underground station is configured. Disable API keys in Settings → Locations to use saved locations."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Custom locations are currently ignored because a Weather Underground station is configured. Disable API keys in Settings → Locations to use saved locations."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le posizioni personalizzate sono attualmente ignorate perché è stata configurata una stazione metropolitana meteo. Disabilita le chiavi API in Impostazioni → Posizioni per utilizzare le posizioni salvate."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
