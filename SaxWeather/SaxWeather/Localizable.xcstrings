        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bezplatná zkušenost – dodaný obrázek předvolby s výchozím tmavým potahem – je k dispozici každému uživateli. Přizpůsobení je odemčeno jedním nákupem v aplikaci."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Den gratis oplevelse - det afsendte forudindstillede billede med standard mørk overlay - er tilgængelig for hver bruger. Tilpasning er låst op af et enkelt køb i appen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das kostenlose Erlebnis – das verschickte Preset-Bild mit dem Standard-dunklen Overlay – steht jedem Benutzer zur Verfügung. Die Anpassung wird durch einen einzigen In-App-Kauf freigeschaltet."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η δωρεάν εμπειρία - η προκαθορισμένη εικόνα που αποστέλλεται με την προεπιλεγμένη σκοτεινή επικάλυψη - είναι διαθέσιμη σε κάθε χρήστη. Η προσαρμογή ξεκλειδώθηκε από μια αγορά εντός εφαρμογής."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La experiencia libre — la imagen preestablecida enviada con la capa oscura por defecto — está disponible para todos los usuarios. La personalización está desbloqueada por una sola compra dentro de la aplicación."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vapaa kokemus – lähetetty esikuva oletuksena tumma peitto – on jokaisen käyttäjän saatavilla. Mukauttaminen on avattu yhdellä sovelluksen sisäisellä ostoksella."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'expérience gratuite — l'image prédéfinie livrée avec la superposition sombre par défaut — est disponible pour chaque utilisateur. La personnalisation est déverrouillée par un seul achat in-app."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
