    "The free experience — the shipped preset image with the default dark overlay — is available to every user. Customisation is unlocked by a single in-app purchase." : {
      "comment" : "Footer explaining the free vs paid background experience.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free experience — the shipped preset image with the default dark overlay — is available to every user. Customisation is unlocked by a single in-app purchase."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free experience — the shipped preset image with the default dark overlay — is available to every user. Customisation is unlocked by a single in-app purchase."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "التجربة المجانية - الصورة المشحونة مسبقاً مع تراكب الظلام الافتراضي - متاحة لكل مستخدم. التخصيص غير مقفل بواسطة عملية شراء واحدة داخل التطبيق."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free experience — the shipped preset image with the default dark overlay — is available to every user. Customisation is unlocked by a single in-app purchase."
