    "\"%@\" will be removed from your saved locations. This cannot be undone." : {
      "comment" : "Delete-location confirmation message. %@ is the location name.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"%@\" will be removed from your saved locations. This cannot be undone."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"%@\" will be removed from your saved locations. This cannot be undone."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيتم إزالة \"%@\" من مواقعك المحفوظة. لا يمكن التراجع عن ذلك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"%@\" will be removed from your saved locations. This cannot be undone."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" bude odstraněn z vašich uložených míst. Tuto akci nelze vrátit zpět."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" vil blive fjernet fra dine gemte steder. Dette kan ikke fortrydes."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" wird von Ihren gespeicherten Orten entfernt. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" θα αφαιρεθεί από τις αποθηκευμένες τοποθεσίες σας. Αυτό δεν μπορεί να αναιρεθεί."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" se eliminará de sus ubicaciones guardadas. Esto no se puede deshacer."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" poistetaan tallennetuista sijainneista. Tätä ei voi peruuttaa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%@» sera supprimé de vos emplacements enregistrés. Cela ne peut pas être annulé."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"%@\" will be removed from your saved locations. This cannot be undone."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"%@\" will be removed from your saved locations. This cannot be undone."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"%@\" will be removed from your saved locations. This cannot be undone."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" sarà rimosso dalle tue posizioni salvate. Questo non può essere annullato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" は保存した場所から削除されます。元に戻すことはできません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"%@\" will be removed from your saved locations. This cannot be undone."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" zal worden verwijderd van uw opgeslagen locaties. Dit kan niet ongedaan worden gemaakt."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" blir fjernet fra dine lagrede steder. Dette kan ikke angres."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" zostanie usunięty z zapisanych lokalizacji. Tej operacji nie można cofnąć."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" será removido das suas localizações salvas. Isso não pode ser desfeito."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" será removido das suas localizações salvas. Isso não pode ser desfeito."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" va fi eliminat din locațiile salvate. Acest lucru nu poate fi anulat."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" будут удалены из сохраненных вами мест. Это действие не может быть отменено."
          }
        },
        "sq" : {
          "stringUnit" : {
            "state" : "new",
