          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Τα κλειδιά Weather Underground και OpenWeatherMap API είναι προς το παρόν απενεργοποιημένα. Μόνο οι καιρικές συνθήκες Apple και Open-Meteo είναι διαθέσιμα."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las claves de la API OpenWeatherMap y Underground están actualmente deshabilitadas. Sólo Apple Weather y Open-Meteo están disponibles."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weather Underground ja OpenWeatherMap API-avaimet ovat tällä hetkellä pois käytöstä. Vain Apple Sää ja Open-Meteo ovat käytettävissä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
