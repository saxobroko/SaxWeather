    "Back up your settings to a .saxtheme file, restore from one, or sync across your devices with iCloud." : {
      "comment" : "Description of backup/restore options. Keep '.saxtheme'.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Back up your settings to a .saxtheme file, restore from one, or sync across your devices with iCloud."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Back up your settings to a .saxtheme file, restore from one, or sync across your devices with iCloud."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بنسخ إعداداتك احتياطياً إلى ملف .saxtheme أو استعادتها من واحد أو مزامنة عبر أجهزتك مع iCloud."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Back up your settings to a .saxtheme file, restore from one, or sync across your devices with iCloud."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zálohujte svá nastavení na .saxtheme soubor, obnovte z něho nebo synchronizujte napříč zařízeními s iCloudem."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sikkerhedskopiere dine indstillinger til en .saxtema fil, gendanne fra en, eller synkronisere på tværs af dine enheder med iCloud."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sichern Sie Ihre Einstellungen in einer .saxtheme-Datei, von einer wiederherstellen oder synchronisieren Sie Ihre Geräte mit iCloud."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Δημιουργήστε αντίγραφα ασφαλείας των ρυθμίσεων σας σε ένα αρχείο .saxtheme, επαναφέρετε από μία, ή συγχρονίστε τις συσκευές σας με το iCloud."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haz una copia de seguridad de tus ajustes en un archivo .saxtheme o restaura desde uno o sincroniza tus dispositivos con iCloud."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Varmuuskopioi asetuksesi .saxthem-tiedostoon, palauta yksi tai synkronoi laitteesi iCloudin kanssa."
          }
        },
