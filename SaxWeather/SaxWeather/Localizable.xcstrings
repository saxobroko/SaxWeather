    "Width 0 removes the border entirely. Outline style uses a 45%-opacity stroke; other styles use 20%." : {
      "comment" : "Footer explaining card border width.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Width 0 removes the border entirely. Outline style uses a 45%-opacity stroke; other styles use 20%."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Width 0 removes the border entirely. Outline style uses a 45%-opacity stroke; other styles use 20%."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "العرض 0 يزيل الحدود كليا. نمط المخطط يستخدم 45%-oسرعة، وأنماط أخرى تستخدم 20 في المائة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Width 0 removes the border entirely. Outline style uses a 45%-opacity stroke; other styles use 20%."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Width 0 removes the border entirely. Outline style uses a 45%-opacity stroke; other styles use 20%."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bredde 0 fjerner grænsen helt. Omrids stil bruger et 45%-opacity slagtilfælde; andre stilarter bruger 20%."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Breite 0 entfernt den Rahmen vollständig. Umriss Stil verwendet einen 45%-oSchritt-Schritt; andere Stile verwenden 20%."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το πλάτος 0 αφαιρεί το περίγραμμα εξ ολοκλήρου. Το στυλ περιγράμματος χρησιμοποιεί ένα εγκεφαλικό επεισόδιο 45%-opacity · άλλα στυλ χρησιμοποιούν 20%."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ancho 0 elimina el borde por completo. El estilo de salida usa un trazo pacity de 45%-o; otros estilos utilizan un 20%."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leveys 0 poistaa rajan kokonaan. Ulkonäön tyyli käyttää 45%-onopeusviivaa; muut tyylit käyttävät 20%."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Largeur 0 supprime complètement la bordure. Le style de contour utilise un trait de capacité de 45%-o. Les autres styles utilisent 20%."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Width 0 removes the border entirely. Outline style uses a 45%-opacity stroke; other styles use 20%."
          }
        },
