        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scegli un preset per un look rapido o scegli un colore personalizzato. Vuoto (\"Predefinito\") significa che la scheda usa il colore della superficie della tavolozza."
          }
        },
        "ja" : {
