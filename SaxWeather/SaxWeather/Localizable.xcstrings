    "Enable notifications to receive rain start/stop alerts and severe weather warnings for your location." : {
      "comment" : "Explanation prompting the user to enable notifications.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Enable notifications to receive rain start/stop alerts and severe weather warnings for your location."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Enable notifications to receive rain start/stop alerts and severe weather warnings for your location."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تمكين الإشعارات لتلقي تنبيهات بدء الأمطار/إيقاف الأمطار وتحذيرات الطقس الشديدة لموقعك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Enable notifications to receive rain start/stop alerts and severe weather warnings for your location."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Povolte upozornění pro startu/zastavení deště a upozornění na vážné počasí pro vaši polohu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktivér notifikationer for at modtage regnstart/stop advarsler og alvorlige vejradvarsler for din placering."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktivieren Sie Benachrichtigungen, um Start-/Stop-Warnungen und schwere Wetterwarnungen für Ihren Standort zu erhalten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ενεργοποιήστε τις ειδοποιήσεις για να λαμβάνετε ειδοποιήσεις εκκίνησης/διακοπής βροχής και σοβαρές προειδοποιήσεις καιρού για την τοποθεσία σας."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Habilita las notificaciones para recibir alertas de inicio o parada de lluvia y advertencias climáticas severas para tu ubicación."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salli ilmoitukset saadaksesi sateen alku/pysäytys hälytyksiä ja ankaria säävaroituksia sijaintisi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activez les notifications pour recevoir des alertes de pluie/arrêt et des avertissements météorologiques sévères pour votre localisation."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Enable notifications to receive rain start/stop alerts and severe weather warnings for your location."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Enable notifications to receive rain start/stop alerts and severe weather warnings for your location."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Enable notifications to receive rain start/stop alerts and severe weather warnings for your location."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abilita le notifiche per ricevere avvisi di avvio/arresto pioggia e avvertimenti meteorologici severi per la tua posizione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "天気予報の通知を有効にすると、雨の開始/停止、天気予報の通知を受け取れます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "new",
