    "Tap a location to use it. Swipe left to delete." : {
      "comment" : "Hint for the locations list.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tap a location to use it. Swipe left to delete."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tap a location to use it. Swipe left to delete."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انقر على موقع لاستخدامه. اسحب لليسار للحذف."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tap a location to use it. Swipe left to delete."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klepnutím na umístění jej použijete. Posunutím vlevo jej odstraníte."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tryk på en placering for at bruge den. Stryg til venstre for at slette."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe auf einen Ort, um ihn zu verwenden. Wische nach links, um ihn zu löschen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Πατήστε μια τοποθεσία για να τη χρησιμοποιήσετε. Σύρετε προς τα αριστερά για διαγραφή."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
