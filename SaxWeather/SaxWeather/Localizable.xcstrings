          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Controlla l'aspetto delle icone meteo — lo stile di colore, i simboli di contorno pieno e le loro dimensioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "天気アイコンの外観、カラースタイル、塗りつぶしとアウトラインシンボルのサイズを制御します。"
