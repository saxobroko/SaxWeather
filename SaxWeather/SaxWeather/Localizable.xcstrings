    "Notifications are off. You can enable them any time in Settings, then Notifications, then SaxWeather." : {
      "comment" : "Status message about disabled notifications. Keep 'SaxWeather'.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Notifications are off. You can enable them any time in Settings, then Notifications, then SaxWeather."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Notifications are off. You can enable them any time in Settings, then Notifications, then SaxWeather."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الإشعارات متوقفة. يمكنك تمكينها في أي وقت من الإعدادات، ثم الإخطارات، ثم ساكسويتر."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Notifications are off. You can enable them any time in Settings, then Notifications, then SaxWeather."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Upozornění jsou vypnuta. Můžete je kdykoliv povolit v Nastavení, poté oznámení, poté SaxWeather."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notifikationer er slået fra. Du kan aktivere dem når som helst i Indstillinger, derefter notifikationer, derefter SaxWeather."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benachrichtigungen sind aus. Sie können sie jederzeit in den Einstellungen, dann in den Benachrichtigungen, dann SaxWeather aktivieren."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι ειδοποιήσεις είναι απενεργοποιημένες. Μπορείτε να τις ενεργοποιήσετε οποιαδήποτε στιγμή στις Ρυθμίσεις, μετά τις Ειδοποιήσεις, μετά το SaxWeather."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las notificaciones están desactivadas. Puede activarlas en cualquier momento en Configuración, luego Notificaciones, luego en SaxWeather."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
