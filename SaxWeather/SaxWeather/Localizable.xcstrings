    "'%@' will replace your current theme." : {
      "comment" : "Confirmation message before importing a theme. %@ is the theme name.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "'%@' will replace your current theme."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "'%@' will replace your current theme."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@سوف يحل محل السمة الحالية الخاصة بك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "'%@' will replace your current theme."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'%@' nahradí tvůj aktuální motiv."
