    "Corner radius and inner padding. Original WeatherDetailsView used 24 pt radius, 16 pt horizontal padding, 20 pt vertical padding." : {
      "comment" : "Developer-facing footer describing card metrics.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Corner radius and inner padding. Original WeatherDetailsView used 24 pt radius, 16 pt horizontal padding, 20 pt vertical padding."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Corner radius and inner padding. Original WeatherDetailsView used 24 pt radius, 16 pt horizontal padding, 20 pt vertical padding."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نصف قطر الزاوية والحواسيب الداخلية. يستخدم WeatherDetailsView الأصلي 24 نصف قطر صباحاً، و 16 بابا أفقيا، و 20 بابا رأسا رأسيا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Corner radius and inner padding. Original WeatherDetailsView used 24 pt radius, 16 pt horizontal padding, 20 pt vertical padding."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poloměr rohů a vnitřní odsazení. Původní WeatherDetailsView použil 24 bodů poloměr, 16 bodů vodorovného odsazení, 20 bodů vertikální odsazení."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Corner radius og indre polstring. Oprindelige VejrdetaljerVis brugte 24 pt radius, 16 pt vandret polstring, 20 pt lodret polstring."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Original WeatherDetailsView verwendet 24 pt Radius, 16 pt horizontale Padding, 20 pt vertikale Padding."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αρχική WeatherDetailsView που χρησιμοποιείται 24 pt ακτίνα, 16 pt οριζόντια padding, 20 pt κάθετη padding."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Radio de esquina y relleno interior. Original WeatherDetailsView usó 24 pm, relleno horizontal de 16 pm, relleno vertical de 20 pts."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kulman säde ja sisäinen pehmusteet. alkuperäinen WeatherDetailsView used 24 pt säde, 16 pt vaakasuora pehmusteet, 20 pt pystysuorassa pehmusteessa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rayon des angles et remplissage intérieur; WeatherDetailsView original utilisait un rayon de 24 pt, un remplissage horizontal de 16 pts, un remplissage vertical de 20 pts."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Corner radius and inner padding. Original WeatherDetailsView used 24 pt radius, 16 pt horizontal padding, 20 pt vertical padding."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Corner radius and inner padding. Original WeatherDetailsView used 24 pt radius, 16 pt horizontal padding, 20 pt vertical padding."
          }
