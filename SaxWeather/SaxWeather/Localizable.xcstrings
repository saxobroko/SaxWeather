          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Queste funzionalità sono in fase di elaborazione. Abilitarle per provarle, quindi il feedback dei file in modo da sapere cosa lucidare ."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これらの機能はワークイン進行中です。それらを有効にして試してフィードバックを提出することで、何を磨くべきかを知ることができます。"
