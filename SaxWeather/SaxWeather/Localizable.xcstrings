    "Manage your saved places, choose data providers, and set the units and forecast options used across the app." : {
      "comment" : "Subtitle for the Weather Data settings entry.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Manage your saved places, choose data providers, and set the units and forecast options used across the app."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Manage your saved places, choose data providers, and set the units and forecast options used across the app."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إدارة الأماكن المحفوظة الخاصة بك، واختيار مزودي البيانات، وتعيين الوحدات وخيارات التنبؤ المستخدمة عبر التطبيق."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Manage your saved places, choose data providers, and set the units and forecast options used across the app."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spravujte svá uložená místa, vyberte poskytovatele dat a nastavte jednotky a možnosti předpovědí používané v celé aplikaci."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Administrer dine gemte steder, vælg dataudbydere, og indstil de enheder og prognosemuligheder, der bruges på tværs af appen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwalten Sie Ihre gespeicherten Orte, wählen Sie Datenanbieter und legen Sie die Einheiten und Vorhersageoptionen fest, die in der App verwendet werden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Διαχειριστείτε τις αποθηκευμένες θέσεις σας, επιλέξτε παρόχους δεδομένων και ορίστε τις μονάδες και τις επιλογές πρόβλεψης που χρησιμοποιούνται στην εφαρμογή."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Administre sus lugares guardados, elija proveedores de datos y establezca las unidades y las opciones de previsión utilizadas a través de la aplicación."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hallitse tallennettuja paikkoja, valitse tietojen tarjoajia ja aseta sovelluksessa käytetyt yksiköt ja ennusteasetukset."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gérez vos lieux enregistrés, choisissez les fournisseurs de données et définissez les unités et les options de prévision utilisées dans l'application."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Manage your saved places, choose data providers, and set the units and forecast options used across the app."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Manage your saved places, choose data providers, and set the units and forecast options used across the app."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Manage your saved places, choose data providers, and set the units and forecast options used across the app."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gestisci i tuoi luoghi salvati, scegli provider di dati e imposta le unità e le opzioni di previsione utilizzate in tutta l'app."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保存された場所を管理し、データプロバイダを選択し、アプリ全体で使用される単位と予測オプションを設定します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Manage your saved places, choose data providers, and set the units and forecast options used across the app."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beheer uw opgeslagen plaatsen, kies dataproviders en stel de eenheden en weersverwachting opties in die in de app worden gebruikt."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Behandle de lagrede stedene, velg dataleverandører, og angi enhetene og prognosealternativene som brukes på tvers av appen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zarządzaj zapisanymi miejscami, wybierz dostawców danych i ustaw jednostki i opcje prognozowania używane w aplikacji."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gerencie seus locais salvos, escolha provedores de dados e defina as unidades e opções de previsão usadas no aplicativo."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gerencie seus locais salvos, escolha provedores de dados e defina as unidades e opções de previsão usadas no aplicativo."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gestionați locurile salvate, alegeți furnizorii de date și setați unitățile și opțiunile de prognoză utilizate în întreaga aplicație."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Управляйте сохраненными местами, выбирайте поставщиков данных и задайте единицы и параметры прогнозирования, используемые в приложении."
