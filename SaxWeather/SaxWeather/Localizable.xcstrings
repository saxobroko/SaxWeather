          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather are nevoie de acces la locație pentru a arăta vremea unde te afli. Poți adăuga o locație manual mai târziu în Setări."
          }
        },
        "ru" : {
