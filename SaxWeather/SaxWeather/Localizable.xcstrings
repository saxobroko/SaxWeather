    "error.apiKey.message" : {
      "comment" : "Error alert message: a weather-service API key is invalid or revoked.",
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "One of your weather service keys is invalid or has been revoked. Open Settings to update it."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "One of your weather service keys is invalid or has been revoked. Open Settings to update it."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أحد مفاتيح خدمة الطقس الخاصة بك غير صالح أو تم إلغاؤه. افتح الإعدادات لتحديثه."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "One of your weather service keys is invalid or has been revoked. Open Settings to update it."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeden z vašich klíčů služby počasí je neplatný nebo byl odvolán. Otevřete nastavení a aktualizujte."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En af dine vejr-tjenestenøgler er ugyldig eller er blevet tilbagekaldt. Åbn indstillinger for at opdatere den."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einer Ihrer Wetterdienstschlüssel ist ungültig oder wurde widerrufen. Öffnen Sie die Einstellungen um sie zu aktualisieren."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ένα από τα κλειδιά υπηρεσίας καιρού σας δεν είναι έγκυρο ή έχει ανακληθεί. Ανοιχτές ρυθμίσεις για να το ενημερώσετε."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "One of your weather service keys is invalid or has been revoked. Open Settings to update it."
          }
        },
