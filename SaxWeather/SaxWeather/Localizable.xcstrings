          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يعين ألوان اللكنة الخمسة للتطبيق إلى البحرية العميقة، الزرقاء في المحيطات، والفحم، والنعناع، والشعاب المرجانية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
