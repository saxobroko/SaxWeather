    "The free Default uses a neutral blue-to-orange gradient. Themed skins are cosmetic add-ons — buy the matching pack to unlock them." : {
      "comment" : "Footer on the chart skin picker section.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free Default uses a neutral blue-to-orange gradient. Themed skins are cosmetic add-ons — buy the matching pack to unlock them."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free Default uses a neutral blue-to-orange gradient. Themed skins are cosmetic add-ons — buy the matching pack to unlock them."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الافتراضي المجاني يستخدم معامل تدرج محايد من اللون الأزرق إلى البرتقالي. الجلود المظاهر هي إضافات تجميلية - اشتري باقة المطابقة لفتح تلك الباقات."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free Default uses a neutral blue-to-orange gradient. Themed skins are cosmetic add-ons — buy the matching pack to unlock them."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Volná výchozí hodnota používá neutrální modrý až oranžový gradient. Domnělé kožešiny jsou kosmetické doplňky — kupte odpovídající balíček k jejich odemčení."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Den gratis standard bruger en neutral blå-til-orange gradient. Themed skind er kosmetiske tilføjelser - køb den matchende pakke for at låse dem op."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der kostenlose Standard verwendet einen neutralen blau-orangenen Farbverlauf. Themed Skins sind kosmetische Zusätze — kaufen Sie das passende Paket, um sie freizuschalten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η δωρεάν προεπιλογή χρησιμοποιεί μια ουδέτερη διαβαθμισμένη μπλε-προ-πορτοκαλί. Τα θεματικά δέρματα είναι καλλυντικά πρόσθετα - αγοράζουν το αντίστοιχο πακέτο για να ξεκλειδώσουν."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El predeterminado gratuito utiliza un degradado neutral azul-a-naranja. Las pieles temáticas son complementos cosméticos — compra el paquete correspondiente para desbloquearlos."
          }
        },
