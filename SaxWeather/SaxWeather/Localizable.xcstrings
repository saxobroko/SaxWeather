    "Glass uses Apple’s translucent material. Solid is opaque. Outline is transparent with a border. Neumorphic adds a soft inner shadow." : {
      "comment" : "Footer explaining card style options.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Glass uses Apple’s translucent material. Solid is opaque. Outline is transparent with a border. Neumorphic adds a soft inner shadow."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Glass uses Apple’s translucent material. Solid is opaque. Outline is transparent with a border. Neumorphic adds a soft inner shadow."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الزجاج يستخدم مادة أبل الشفافة. الصلابة غامضة. المخطط شفاف مع الحدود. النومورفيك يضيف ظل داخلي ناعم."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Glass uses Apple’s translucent material. Solid is opaque. Outline is transparent with a border. Neumorphic adds a soft inner shadow."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skleněné sklo používá průsvitný materiál Applu. Pevný je neprůhledný. Obrys je průhledný s okrajem. Neumorfický přidává měkký vnitřní stín."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Glas bruger Apples gennemsigtige materiale. Solid er uigennemsigtig. Omrids er gennemsigtig med en grænse. Neumorfe tilføjer en blød indre skygge."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Glas verwendet das transparente Material von Apple. Solid ist undurchsichtig. Die Kontur ist transparent mit einer Grenze. Neumorph fügt einen weichen inneren Schatten hinzu."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το γυαλί χρησιμοποιεί το ημιδιαφανές υλικό της Apple. Το στερεό είναι αδιαφανές. Το περίγραμμα είναι διαφανές με ένα περίγραμμα."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El cristal utiliza material translúcido de Apple. Sólido es opaco. La salida es transparente con un borde. Neumórfico añade una sombra interior suave."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lasi käyttää Applen läpikuultava materiaali. Kiinteä on läpinäkymätöntä. Ulkoviiva on läpinäkyvä rajalla. Neumorphic lisää pehmeä sisempi varjo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le verre utilise le matériau translucide d'Apple. Solide est opaque. Le contour est transparent avec une bordure. Neumorphique ajoute une ombre intérieure douce."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Glass uses Apple’s translucent material. Solid is opaque. Outline is transparent with a border. Neumorphic adds a soft inner shadow."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Glass uses Apple’s translucent material. Solid is opaque. Outline is transparent with a border. Neumorphic adds a soft inner shadow."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Glass uses Apple’s translucent material. Solid is opaque. Outline is transparent with a border. Neumorphic adds a soft inner shadow."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vetro utilizza il materiale traslucido di Apple. Solid è opaco. Outline è trasparente con un bordo. Neumorfo aggiunge una morbida ombra interna."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ガラスはAppleの半透明素材を使用しています。ソリッドは不透明です。アウトラインは境界線で透明です。ノイモルフィックは柔らかい内側の影を追加します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Glass uses Apple’s translucent material. Solid is opaque. Outline is transparent with a border. Neumorphic adds a soft inner shadow."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Glas gebruikt Apple's doorschijnend materiaal. Solid is ondoorzichtig. Omlijning is transparant met een grens. Neumorfe voegt een zachte innerlijke schaduw toe."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Glass bruker Gjennomskinnelige materialer Aple. Solid er ugjennomsiktig. Utsiden er gjennomsiktig med en grense. Neumorfe tilfører en myk indre skygge."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Szkło używa przezroczystego materiału jabłka. Solidny jest nieprzezroczysty. Obrys jest przezroczysty z obramowaniem. Neumorphic dodaje miękki wewnętrzny cień."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O vidro usa o material translúcido da Apple. Sólido é opaco. Contorno é transparente com uma borda. Neumorfo adiciona uma sombra suave no interior."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O vidro usa o material translúcido da Apple. Sólido é opaco. Contorno é transparente com uma borda. Neumorfo adiciona uma sombra suave no interior."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sticla folosește material translucid Apple. Solid este opac. Contextul este transparent cu o graniță. Neumorphic adaugă o umbră interioară."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Стекло использует полупрозрачный материал яблока. Твердый - непрозрачный. Контур прозрачен границей. Неймоморфический добавляет мягкую внутреннюю тень."
          }
        },
        "sq" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Glass uses Apple’s translucent material. Solid is opaque. Outline is transparent with a border. Neumorphic adds a soft inner shadow."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Glass uses Apple’s translucent material. Solid is opaque. Outline is transparent with a border. Neumorphic adds a soft inner shadow."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Glas använder Apples genomskinliga material. Solid är ogenomskinlig. Dispositionen är transparent med en bård. Neumorphic ger en mjuk inre skugga."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Glass uses Apple’s translucent material. Solid is opaque. Outline is transparent with a border. Neumorphic adds a soft inner shadow."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Скло використовує напівпрозорий матеріал Apple. Тверді непрозорий. Контур прозорий з кордоном. Нейморфічний додає м'яку внутрішню тінь."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Glass uses Apple’s translucent material. Solid is opaque. Outline is transparent with a border. Neumorphic adds a soft inner shadow."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "玻璃使用苹果的半透明材料。固体是不透明的。轮廓与边框透明。内脏添加软内幕阴影。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Glass uses Apple’s translucent material. Solid is opaque. Outline is transparent with a border. Neumorphic adds a soft inner shadow."
          }
        }
      }
    },
