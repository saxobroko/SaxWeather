            "value" : "今までに出荷されたすべての化粧品や未来の化粧品を自動的にロック解除する一回限りの購入。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "A single one-time purchase that unlocks every current cosmetic and every future cosmetic we ever ship, automatically."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
