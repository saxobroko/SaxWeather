    "Change the background image, set a gradient, tint the preset, swap images by condition, switch by time of day, and tune the dark overlay." : {
      "comment" : "Subtitle for background customisation.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Change the background image, set a gradient, tint the preset, swap images by condition, switch by time of day, and tune the dark overlay."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Change the background image, set a gradient, tint the preset, swap images by condition, switch by time of day, and tune the dark overlay."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بتغيير صورة الخلفية، عيّن معامل تدرج، صبغة مسبقة، مقايضة الصور بشروط، التبديل بالوقت من اليوم، وضبط التداخل المظلم."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Change the background image, set a gradient, tint the preset, swap images by condition, switch by time of day, and tune the dark overlay."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Změna obrázku pozadí, nastavení gradientu, odstín předvolby, odkládání obrázků podle podmínek, přepnutí podle denní doby a vyladění tmavého překrytí."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ændre baggrundsbilledet, indstille en stigning, toning forudindstillet, bytte billeder efter tilstand, skifte efter tid på dagen, og tune den mørke overlay."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ändern Sie das Hintergrundbild, setzen Sie einen Farbverlauf, färben Sie das Preset, tauschen Sie Bilder nach Zustand, wechseln Sie nach Tageszeit und stimmen Sie das dunkle Overlay ein."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αλλάξτε την εικόνα φόντου, ορίστε μια διαβάθμιση, απόχρωση της προκαθορισμένης, εναλλαγή εικόνων ανά κατάσταση, εναλλαγή κατά την ώρα της ημέρας και ρυθμίστε τη σκοτεινή επικάλυψη."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambie la imagen de fondo, establezca un degradado, coloque el ajuste preestablecido, cambie las imágenes por condición, cambie por hora del día y ajuste la superposición oscura."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muuta taustakuvaa, aseta kaltevuus, sävytä esiasetus, vaihda kuvia kunnossa, kytke kellonaika päivän, ja viritä tumma päällekkäisyys."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Changez l'image d'arrière-plan, définissez un dégradé, teignez le préréglage, échangez les images par état, basculez par heure de la journée et réglez la superposition sombre."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Change the background image, set a gradient, tint the preset, swap images by condition, switch by time of day, and tune the dark overlay."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Change the background image, set a gradient, tint the preset, swap images by condition, switch by time of day, and tune the dark overlay."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Change the background image, set a gradient, tint the preset, swap images by condition, switch by time of day, and tune the dark overlay."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambia l'immagine di sfondo, imposta un gradiente, tinta il preset, cambia le immagini per condizione, passa per ora del giorno e sintona la sovrapposizione scura."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "背景画像を変更し、グラデーションを設定し、プリセットを色付けし、画像を条件でスワップし、時間単位でスイッチし、ダークオーバーレイを調整します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Change the background image, set a gradient, tint the preset, swap images by condition, switch by time of day, and tune the dark overlay."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wijzig de achtergrondafbeelding, stel een verloop, tint de voorkeur, verander afbeeldingen op voorwaarde, schakel over op tijd van de dag en pas de donkere overlay."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Endre bakgrunnsbildet, sett en gradient, fargetone forhåndsinnstillingen, bytter bilder med betingelse, bryter med tidspunkt på døgnet, og juster de mørke overgangen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zmień obraz tła, ustaw gradient, przyciemnij ustawienia, zamień obrazy przez warunek, przełącz na godzinę dnia i dostosuj ciemny nakładek."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alterar a imagem de fundo, definir um gradiente, cor da predefinição, trocar imagens por condição, alternar por horário do dia e ajustar a sobreposição escura."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alterar a imagem de fundo, definir um gradiente, cor da predefinição, trocar imagens por condição, alternar por horário do dia e ajustar a sobreposição escura."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schimbă imaginea de fundal, setează un gradient, micșorează presetarea, schimbă imaginile în funcție de condiție, schimbă ora de zi și reglează suprapunerea întunecată."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Изменим фоновое изображение, зададим градиент, оттенок пресета, переключать изображения по условиям, переключаться на время суток и настраивать накладываемое изображение."
          }
        },
        "sq" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Change the background image, set a gradient, tint the preset, swap images by condition, switch by time of day, and tune the dark overlay."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Change the background image, set a gradient, tint the preset, swap images by condition, switch by time of day, and tune the dark overlay."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ändra bakgrundsbilden, ange en gradient, tona förinställda, byta bilder efter skick, växla med tiden på dagen, och justera den mörka överlaget."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Change the background image, set a gradient, tint the preset, swap images by condition, switch by time of day, and tune the dark overlay."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Змініть фонове зображення, встановіть градієнт, відтінити пресет, змінити образи за станом, перемикатися по часу доби і настроїти темний шар."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Change the background image, set a gradient, tint the preset, swap images by condition, switch by time of day, and tune the dark overlay."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "更改背景图像，设置渐变，调整预设，按条件交换图像，按时间切换，并调整暗色叠加层。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Change the background image, set a gradient, tint the preset, swap images by condition, switch by time of day, and tune the dark overlay."
          }
        }
      }
    },
