    "Overrides the solid border with a top-leading → bottom-trailing gradient. Leave both colours on “System” to fall back to the solid border." : {
      "comment" : "Footer explaining the border gradient option.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Overrides the solid border with a top-leading → bottom-trailing gradient. Leave both colours on “System” to fall back to the solid border."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Overrides the solid border with a top-leading → bottom-trailing gradient. Leave both colours on “System” to fall back to the solid border."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتغلب على الحدود الصلبة مع معامل تدرج قيادي من الأسفل إلى القاع. يترك كلا اللونين على \"النظام\" ليعودا إلى الحدود الصلبة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Overrides the solid border with a top-leading → bottom-trailing gradient. Leave both colours on “System” to fall back to the solid border."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přepíše pevné ohraničení horním úhlem → dolní a koncový gradient. Ponechte obě barvy v „Systému“, aby se vrátila k pevnému okraji."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overstyrer den solide kant med en top-ledende → bund-trailing gradient. Lad begge farver på “System” for at falde tilbage til den faste grænse."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Überschreibt den festen Rand mit einem oberen Rand → unten am Ende des Verlaufs."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Παρακάμπτει το συμπαγές περίγραμμα με κορυφαία → κατώτατο όριο διαβάθμισης. Αφήστε και τα δύο χρώματα στο «Σύστημα» για να πέσει πίσω στο συμπαγές περίγραμμα."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobrescribe el borde sólido con un degradado superior → inferior y deja ambos colores en “Sistema” para caer de nuevo al borde sólido."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ohittaa kiinteän rajan, jolla on ylhäältä johtava → alhaalta alaspäin kulkeva kaltevuus. Jätä molemmat värit ”Järjestelmässä” takaisin kiinteään rajaan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Outrepasse la bordure solide avec un dégradé supérieur → inférieur à suivant. Laissez les deux couleurs sur « Système » pour revenir à la bordure solide."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Overrides the solid border with a top-leading → bottom-trailing gradient. Leave both colours on “System” to fall back to the solid border."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Overrides the solid border with a top-leading → bottom-trailing gradient. Leave both colours on “System” to fall back to the solid border."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Overrides the solid border with a top-leading → bottom-trailing gradient. Leave both colours on “System” to fall back to the solid border."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sovrascrive il bordo solido con una pendenza dal basso superiore → dal basso. Lascia entrambi i colori su “Sistema” per tornare al bordo solido."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "上位の→ 下位の勾配でソリッドの境界線を上書きします。「システム」の両方の色を残して、ソリッドの境界線に戻ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Overrides the solid border with a top-leading → bottom-trailing gradient. Leave both colours on “System” to fall back to the solid border."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hiermee overschrijft u de solide rand met een bovenste leiding → looploophoogte onderaan. Laat beide kleuren op \"Systeem\" staan om terug te vallen op de vaste grens."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overstyrer den faste kanten med en topp-ledende → bunn-etterfølgende gradient. La begge fargene på “System” stå tilbake til den solide grensen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zastępuje stałe obramowanie górną krawędzią → dolną krawędź gradientu. Pozostaw oba kolory na „System”, aby wrócić do stałego obramowania."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobrepõe a borda sólida com um gradiente líder → no final do caminho. Deixe ambas as cores em \"Sistema\" para voltar à borda sólida."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobrepõe a borda sólida com um gradiente líder → no final do caminho. Deixe ambas as cores em \"Sistema\" para voltar à borda sólida."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suprascrie graniţa solidă cu un gradient de sus → de jos în jos. Lăsaţi ambele culori pe \"Sistem\" pentru a reveni la graniţa solidă."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Переопределяет твердую границу с верхним → нижним конечным градиентом. Оставьте оба цвета на «Системе», чтобы вернуться на твердую границу."
          }
        },
        "sq" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Overrides the solid border with a top-leading → bottom-trailing gradient. Leave both colours on “System” to fall back to the solid border."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Overrides the solid border with a top-leading → bottom-trailing gradient. Leave both colours on “System” to fall back to the solid border."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Åsidosätter den fasta gränsen med en topp-ledande → botten-avslutande lutning. Lämna båda färgerna på “System” att falla tillbaka till den fasta gränsen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Overrides the solid border with a top-leading → bottom-trailing gradient. Leave both colours on “System” to fall back to the solid border."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Замінює верхню керівну межу → градієнт низу. Залиште обидві кольори в «Системі», щоб повернутися до суцільних кордонів."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Overrides the solid border with a top-leading → bottom-trailing gradient. Leave both colours on “System” to fall back to the solid border."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用一顶尖的 -> 底部拖动梯度覆盖固态边界。将两种颜色留在“系统”上以回到实力边境。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Overrides the solid border with a top-leading → bottom-trailing gradient. Leave both colours on “System” to fall back to the solid border."
          }
        }
      }
    },
