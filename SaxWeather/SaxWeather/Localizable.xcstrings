            "value" : "Override the mode for individual conditions. Empty entries fall through to the global mode."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تجاوز الوضع للظروف الفردية. المدخلات الفارغة تقع في الوضع العام."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Override the mode for individual conditions. Empty entries fall through to the global mode."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přepsat režim pro jednotlivé podmínky. Prázdné vstupy klesnou do globálního režimu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tilsidesæt tilstanden for individuelle forhold. Tomme indgange falder igennem til den globale tilstand."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Überschreiben Sie den Modus für individuelle Bedingungen. Leere Einträge fallen in den globalen Modus."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Παράκαμψη της λειτουργίας για μεμονωμένες συνθήκες. Οι κενές καταχωρήσεις πέφτουν στην καθολική λειτουργία."
          }
        },
        "es" : {
