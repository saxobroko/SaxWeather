          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Et enkelt engangskjøp som låser opp hver nåværende kosmetikk og alle fremtidige kosmetikk vi noen gang skip, automatisk."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
