            "value" : "Breedte 0 verwijdert de grens volledig. Buitenlijnstijl gebruikt een 45%-opacity beroert; andere stijlen gebruiken 20%."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
