    "SaxWeather needs location access to show weather for where you are. You can add a location manually later in Settings." : {
      "comment" : "Location permission explanation. Keep 'SaxWeather'.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "SaxWeather needs location access to show weather for where you are. You can add a location manually later in Settings."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "SaxWeather needs location access to show weather for where you are. You can add a location manually later in Settings."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحتاج SaxWeather إلى الوصول إلى الموقع لإظهار الطقس من أين أنت . يمكنك إضافة موقع يدوياً في وقت لاحق من الإعدادات."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "SaxWeather needs location access to show weather for where you are. You can add a location manually later in Settings."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather potřebuje přístup k poloze pro zobrazení počasí tam, kde jste. Později můžete přidat polohu ručně v nastavení."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather behøver lokationsadgang for at vise vejret, hvor du befinder dig. Du kan tilføje en lokation manuelt senere i Indstillinger."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather benötigt Standortzugriff, um das Wetter dort anzuzeigen, wo Sie sind. Sie können einen Standort später manuell in den Einstellungen hinzufügen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το SaxWeather χρειάζεται πρόσβαση στην τοποθεσία για να δείξει τον καιρό που βρίσκεστε. Μπορείτε να προσθέσετε μια τοποθεσία χειροκίνητα αργότερα στις Ρυθμίσεις."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather necesita acceso a la ubicación para mostrar el tiempo donde estás. Puede añadir una ubicación manualmente más tarde en Configuración."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather tarvitsee sijainnin pääsyn näyttääksesi säätilan missä olet. Voit lisätä sijainnin manuaalisesti myöhemmin Asetuksissa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather a besoin d'un accès à la localisation pour afficher la météo où vous vous trouvez. Vous pouvez ajouter un emplacement manuellement plus tard dans les paramètres."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "SaxWeather needs location access to show weather for where you are. You can add a location manually later in Settings."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "SaxWeather needs location access to show weather for where you are. You can add a location manually later in Settings."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "SaxWeather needs location access to show weather for where you are. You can add a location manually later in Settings."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather ha bisogno di accesso alla posizione per mostrare il tempo per dove ti trovi. Puoi aggiungere una posizione manualmente nelle Impostazioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeatherは現在地を表示するために位置情報のアクセス権を必要とします。位置情報は後で設定から追加できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "SaxWeather needs location access to show weather for where you are. You can add a location manually later in Settings."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saksen hebben locatie nodig om weer te kunnen laten zien waar u bent. U kunt later een locatie toevoegen in Instellingen."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather trenger stedstilgang for å vise været for hvor du er. Du kan legge til en plassering manuelt senere i innstillingene."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaksWeather potrzebuje dostępu do lokalizacji, aby pokazać pogodę dla miejsca, gdzie jesteś. Możesz dodać lokalizację ręcznie później w Ustawieniach."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather precisa de acesso à localização para mostrar o clima de onde você está. Você pode adicionar uma localização manualmente mais tarde nas Configurações."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
