    "Tint lays a soft wash over the card. Overlay layers a warm/cool gradient on top of everything. Original look used a dark wash at 20%." : {
      "comment" : "Footer explaining card tint and overlay.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tint lays a soft wash over the card. Overlay layers a warm/cool gradient on top of everything. Original look used a dark wash at 20%."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tint lays a soft wash over the card. Overlay layers a warm/cool gradient on top of everything. Original look used a dark wash at 20%."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تلميد يرسي غسلا ناعما فوق البطاقة. يرفع الطبقات الطبقات الدفقية/الباردة فوق كل شيء. يبدو الأصلي يستخدم غسيل مظلم بنسبة 20%."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tint lays a soft wash over the card. Overlay layers a warm/cool gradient on top of everything. Original look used a dark wash at 20%."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tint vytváří měkké mytí nad kartou. Překrytí vrací teplý a chladný gradient nad vším. Původní vzhled použil tmavý myší na 20%."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tint lægger en blød vask over kortet. Overlay lag en varm / kølig gradient oven på alt. Original look brugte en mørk vask på 20%."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tint legt eine weiche Wasche über die Karte. Überlagert Schichten einen warm/kühlen Farbverlauf auf alles. Original Aussehen verwendet eine dunkle Wasche bei 20%."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το Tint βάζει ένα μαλακό πλύσιμο πάνω από την κάρτα. Η επικάλυψη βάζει μια ζεστή / δροσερή κλίση πάνω από τα πάντα. Αρχικό βλέμμα χρησιμοποιείται μια σκούρα πλύση στο 20%."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tinta coloca un lazo suave sobre la tarjeta. Supera las capas de un degradado cálido y fresco encima de todo. La apariencia original usaba una lupa oscura al 20%."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tint asettaa pehmeän pesun kortin päälle. Peittokerrokset lämmin/viileän kaltevuuden kaiken päälle. Alkuperäinen näyttää käyttävän tummaa pesua 20 prosentissa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La teinte pose un lavage doux sur la carte. Elle superpose un dégradé chaud/froid au-dessus de tout. L'aspect original utilise un lavage foncé à 20%."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tint lays a soft wash over the card. Overlay layers a warm/cool gradient on top of everything. Original look used a dark wash at 20%."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tint lays a soft wash over the card. Overlay layers a warm/cool gradient on top of everything. Original look used a dark wash at 20%."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tint lays a soft wash over the card. Overlay layers a warm/cool gradient on top of everything. Original look used a dark wash at 20%."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tinta depone un morbido lavaggio sopra la carta. Sovrapponi gli strati di un gradiente caldo / fresco sopra tutto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "薄い色合いはカードの上に柔らかいウォッシュをかけます。オーバーレイはすべての上に暖かい/冷たいグラデーションを重ねます。オリジナルの外観は20%の暗い洗浄を使用しました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tint lays a soft wash over the card. Overlay layers a warm/cool gradient on top of everything. Original look used a dark wash at 20%."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tint legt een zachte was over de kaart. Overlay laagt een warm/coole gradiënt bovenop alles. Origineel ziet er uit als een donkere was op 20%."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tint legger en myk vask over kortet. Overlappe en varmer/kald gradient over alt. Opprinnelig ser ut til å se en mørk vask med 20%."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tint odtwarza miękkie mycie na karcie. Nakładka warstwa gradientu ciepłego/chłodnego na wierzchu wszystkiego. Oryginalny wygląd użyto ciemnego mycia na poziomie 20%."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tint coloca uma lave sobre o cartão. Camadas de sobreposição um gradiente quente/legal em cima de tudo. O visual original usou uma lavagem escura em 20%."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tint coloca uma lave sobre o cartão. Camadas de sobreposição um gradiente quente/legal em cima de tudo. O visual original usou uma lavagem escura em 20%."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tint pune o spălare moale deasupra cardului. Suprapunere un gradient cald/rece peste tot. Aspectul original a folosit o spălare întunecată la 20%."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Подсказка наносит мягкую мойку над картой. Накладывайте слои теплый/прохладный градиент на вершине всего. Исходный вид использовал темную мойку с 20%."
          }
        },
        "sq" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tint lays a soft wash over the card. Overlay layers a warm/cool gradient on top of everything. Original look used a dark wash at 20%."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tint lays a soft wash over the card. Overlay layers a warm/cool gradient on top of everything. Original look used a dark wash at 20%."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tint lägger en mjuk tvätt över kortet. Overlay lager en varm / cool lutning ovanpå allt. Original look används en mörk tvätt på 20%."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tint lays a soft wash over the card. Overlay layers a warm/cool gradient on top of everything. Original look used a dark wash at 20%."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Підказка накладає м'який м'які перемивання на карту. Накладення шарів темного/охолоджуючої градієнта поверх неї. Для цього потрібно вибрати темну пому 20%."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tint lays a soft wash over the card. Overlay layers a warm/cool gradient on top of everything. Original look used a dark wash at 20%."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tint在卡片上放下软瓦片。覆盖图层、温暖/酷渐变在所有东西上。原始看起来使用了20%的黑暗浪。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tint lays a soft wash over the card. Overlay layers a warm/cool gradient on top of everything. Original look used a dark wash at 20%."
          }
        }
      }
    },
    "To use custom locations, disable API keys above or remove Weather Underground credentials in Weather Data settings." : {
      "comment" : "Guidance about using saved locations with Weather Underground.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "To use custom locations, disable API keys above or remove Weather Underground credentials in Weather Data settings."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "To use custom locations, disable API keys above or remove Weather Underground credentials in Weather Data settings."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لاستخدام مواقع مخصصة، قم بتعطيل مفاتيح API فوق أو إزالة بيانات اعتماد Weather Underground في إعدادات بيانات الطقس."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "To use custom locations, disable API keys above or remove Weather Underground credentials in Weather Data settings."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chcete-li používat vlastní lokace, zakažte výše uvedené API klíče nebo odstraňte přihlašovací údaje o počasí v nastavení dat počasí."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deaktivér API-nøgler ovenfor eller fjern Weather Underground legitimationsoplysninger i indstillingerne for vejrdata."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um eigene Standorte zu verwenden, deaktivieren Sie die API-Schlüssel oberhalb oder entfernen Sie die Wetterdaten in den Wetterdaten-Einstellungen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Για να χρησιμοποιήσετε προσαρμοσμένες τοποθεσίες, απενεργοποιήστε τα κλειδιά API παραπάνω ή αφαιρέστε τα διαπιστευτήρια Weather Underground στις ρυθμίσεις καιρικών δεδομένων."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para usar ubicaciones personalizadas, deshabilite las claves de la API de arriba o elimine las credenciales de tiempo bajo tierra en la configuración de datos meteorológicos."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Käyttääksesi mukautettuja sijainteja, poista yllä olevat API-avaimet käytöstä tai poista Weather Underground -käyttäjätiedot Säätietojen asetuksista."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour utiliser des emplacements personnalisés, désactivez les clés API ci-dessus ou supprimez les identifiants Weather Underground dans les paramètres de données météo."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "To use custom locations, disable API keys above or remove Weather Underground credentials in Weather Data settings."
          }
        },
        "hu" : {
