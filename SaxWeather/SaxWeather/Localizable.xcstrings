    "Choose a preset for a quick look, or pick a custom colour. Empty (\"Default\") means the card uses your palette surface colour." : {
      "comment" : "Footer explaining card colour choices.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Choose a preset for a quick look, or pick a custom colour. Empty (\"Default\") means the card uses your palette surface colour."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Choose a preset for a quick look, or pick a custom colour. Empty (\"Default\") means the card uses your palette surface colour."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اختر الإعداد المسبق لمظهر سريع، أو اختر لون مخصص. يعني أن البطاقة تستخدم لون السطح الخاص بك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Choose a preset for a quick look, or pick a custom colour. Empty (\"Default\") means the card uses your palette surface colour."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vyberte si předvolbu pro rychlý vzhled, nebo vyberte vlastní barvu. Prázdná (\"Výchozí\") znamená, že karta používá barvu palety."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vælg en forudindstilling for et hurtigt look, eller vælg en brugerdefineret farve. Tom (\"Standard\") betyder, at kortet bruger din palet overflade farve."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wählen Sie eine Voreinstellung für ein schnelles Aussehen oder wählen Sie eine benutzerdefinierte Farbe. Leer (\"Standard\") bedeutet, dass die Karte Ihre Farbpalette auf der Oberfläche verwendet."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Επιλέξτε μια προεπιλογή για μια γρήγορη εμφάνιση ή επιλέξτε ένα προσαρμοσμένο χρώμα. Κενό (\"Προεπιλογή\") σημαίνει ότι η κάρτα χρησιμοποιεί το χρώμα της επιφάνειας παλέτας."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elija un ajuste predefinido para una mirada rápida, o elija un color personalizado."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valitse pikakuvake tai valitse mukautettu väri. Tyhjä (\"Oletus\") tarkoittaa, että kortti käyttää paletin pinnan väriä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez un préréglage pour un look rapide, ou choisissez une couleur personnalisée. Vide (\"Défaut\") signifie que la carte utilise la couleur de surface de votre palette."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Choose a preset for a quick look, or pick a custom colour. Empty (\"Default\") means the card uses your palette surface colour."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Choose a preset for a quick look, or pick a custom colour. Empty (\"Default\") means the card uses your palette surface colour."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Choose a preset for a quick look, or pick a custom colour. Empty (\"Default\") means the card uses your palette surface colour."
