          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi kunde inte bestämma din nuvarande plats. Se till att du är utomhus eller nära ett fönster och försök igen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "We couldn't determine your current location. Make sure you're outdoors or near a window and try again."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ми не змогли визначити ваше поточне місцезнаходження. Переконайтеся, що ви на вулиці або біля вікна і повторіть спробу."
          }
        },
        "vi" : {
          "stringUnit" : {
