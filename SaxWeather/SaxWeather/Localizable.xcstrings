    "error.locationRestricted.message" : {
      "comment" : "Error alert message: location services restricted.",
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Location services are restricted on this device. You can still add a location manually."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Location services are restricted on this device. You can still add a location manually."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خدمات الموقع مقيدة على هذا الجهاز. لا يزال بإمكانك إضافة موقع يدوياً."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Location services are restricted on this device. You can still add a location manually."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Služby určování polohy jsou omezeny na tomto zařízení. Stále můžete přidat polohu ručně."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Placeringstjenester er begrænset på denne enhed. Du kan stadig tilføje en placering manuelt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standortdienste sind auf diesem Gerät eingeschränkt. Sie können einen Standort manuell hinzufügen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι υπηρεσίες τοποθεσίας περιορίζονται σε αυτήν τη συσκευή. Μπορείτε ακόμα να προσθέσετε μια τοποθεσία χειροκίνητα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Location services are restricted on this device. You can still add a location manually."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los servicios de ubicación están restringidos en este dispositivo. Todavía puede añadir una ubicación manualmente."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sijaintipalvelut ovat rajoitettuja tällä laitteella. Voit silti lisätä sijainnin manuaalisesti."
          }
        },
