    "Buy once, get every cosmetic — now and forever. Help fund the app you love." : {
      "comment" : "Subtitle for the Supporter Pack cosmetic tile.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Buy once, get every cosmetic — now and forever. Help fund the app you love."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Buy once, get every cosmetic — now and forever. Help fund the app you love."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اشتري مرة واحدة، احصل على كل مستحضرات التجميل - الآن وإلى الأبد. ساعد في تمويل التطبيق الذي تحبه."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Buy once, get every cosmetic — now and forever. Help fund the app you love."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kupte si jednou, získejte každý kosmetický — teď a navždy. Pomozte financovat aplikaci, kterou milujete."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Køb én gang, få hver kosmetik - nu og for evigt. Hjælp med at finansiere den app, du elsker."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaufe einmal, bekomme jede Kosmetik – jetzt und immer. Hilf mit, die App zu finanzieren, die du liebst."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αγοράστε μια φορά, πάρτε κάθε καλλυντικό - τώρα και για πάντα. Βοηθήστε να χρηματοδοτήσετε την εφαρμογή που αγαπάτε."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compra una vez, consigue cada cosmético — ahora y para siempre. Ayuda a financiar la aplicación que te gusta."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osta kerran, hanki kaikki kosmetiikka - nyt ja ikuisesti. Auta rahoittamaan rakastamasi sovellus."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Achetez une fois, obtenez chaque cosmétique — maintenant et pour toujours. Aidez à financer l'application que vous aimez."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Buy once, get every cosmetic — now and forever. Help fund the app you love."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Buy once, get every cosmetic — now and forever. Help fund the app you love."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Buy once, get every cosmetic — now and forever. Help fund the app you love."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acquista una volta, ottieni ogni cosmetico — ora e per sempre. Aiuta a finanziare l'app che ami."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一度購入すると、すべての化粧品を手に入れることができます。あなたが愛するアプリに資金を提供するのを助けてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Buy once, get every cosmetic — now and forever. Help fund the app you love."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Koop eenmaal een keer, krijg elke cosmetische ingreep - nu en voor altijd. Help met het financieren van de app waar je van houdt."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kjøp en gang, få hver kosmetikk — nå og for alltid. Hjelp til å finansiere appen du elsker."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kup raz, zdobądź każdy kosmetyczny — teraz i na zawsze. Pomóż finansować aplikację, którą kochasz."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compre uma vez, obtenha todos os cosméticos — agora e para sempre. Ajude a financiar o aplicativo que você ama."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compre uma vez, obtenha todos os cosméticos — agora e para sempre. Ajude a financiar o aplicativo que você ama."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cumpără o dată, ia toate produsele cosmetice — acum și pentru totdeauna. Ajută-ne să finanțăm aplicația pe care o iubești."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Купите один раз, получите все косметические — сейчас и навсегда. Помогите финансировать любимое приложение."
          }
        },
        "sq" : {
