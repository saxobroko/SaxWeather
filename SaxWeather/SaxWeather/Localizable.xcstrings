    "Owned cosmetic palettes and chart skins. Locked rows open the cosmetics store when tapped." : {
      "comment" : "Footer for the owned-cosmetics list.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Owned cosmetic palettes and chart skins. Locked rows open the cosmetics store when tapped."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Owned cosmetic palettes and chart skins. Locked rows open the cosmetics store when tapped."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لوحات مستحضرات التجميل ولوحات المخطط. صفوف مقفلة تفتح متجر مستحضرات التجميل عند النقر عليه."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Owned cosmetic palettes and chart skins. Locked rows open the cosmetics store when tapped."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vlastněné kosmetické palety a vzhledy. Uzamčené řádky otevírají kosmetický obchod při použití."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ejede kosmetiske paletter og kortskind. Låste rækker åbne kosmetik butikken, når tapped."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eigene kosmetische Paletten und Skins. Gesperrte Reihen öffnen das Kosmetikgeschäft beim Drücken der Karte."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Κατάλληλες καλλυντικές παλέτες και δέρματα γραφήματος. Κλειδωμένες σειρές ανοίγουν το κατάστημα καλλυντικών όταν πατηθούν."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las filas bloqueadas abren el almacén de cosméticos cuando son tocadas."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omistetut kosmetiikkapaletit ja kartongit. Lukitut rivit avaavat kosmetiikkamyymälän nauhoitettaessa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
