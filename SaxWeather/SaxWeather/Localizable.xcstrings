    "Weather Underground and OpenWeatherMap API keys are currently disabled. Only Apple Weather and Open-Meteo are available." : {
      "comment" : "Status footer about disabled API keys. Keep source names.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Weather Underground and OpenWeatherMap API keys are currently disabled. Only Apple Weather and Open-Meteo are available."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Weather Underground and OpenWeatherMap API keys are currently disabled. Only Apple Weather and Open-Meteo are available."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مفاتيح API الخاصة بالطقس تحت الأرض و OpenWeatherMap معطلة حاليا. يتوفر فقط الطقس و Open-Meteo."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Weather Underground and OpenWeatherMap API keys are currently disabled. Only Apple Weather and Open-Meteo are available."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klávesy API počasí a OpenWeatherMap jsou momentálně zakázány. K dispozici jsou pouze Apple počasí a Open-Meteo."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weather Underground og OpenWeatherMap API-nøgler er i øjeblikket deaktiveret. Kun Apple Weather og Open-Meteo er tilgængelige."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
