          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nastaví pět zvýrazněných barev aplikace na hluboké námořnictvo, oceánskou modrá, slzu, mince a korály."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sætter appens fem accent farver til dyb flåde, havblå, grå, mynte og koral."
          }
