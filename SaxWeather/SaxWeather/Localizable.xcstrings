    "A single one-time purchase that unlocks every current cosmetic and every future cosmetic we ever ship, automatically." : {
      "comment" : "Long description for Supporter Pack.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
