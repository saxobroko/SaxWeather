    "error.httpRateLimited.message" : {
      "comment" : "Error alert message: rate limited (HTTP 429).",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Too many requests — the weather service asked us to slow down. We'll try again shortly."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Too many requests — the weather service asked us to slow down. We'll try again shortly."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "طلبات كثيرة جدا - طلبت منا خدمة الطقس أن نبطئ. سنحاول مرة أخرى قريبا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Too many requests — the weather service asked us to slow down. We'll try again shortly."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Příliš mnoho požadavků - služba pro počasí nás požádala o zpomalení. Zkusíme to za chvíli."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For mange anmodninger — vejrtjenesten bad os om at bremse. Vi vil forsøge igen om kort tid."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zu viele Anfragen — der Wetterdienst bat uns zu verlangsamen. Wir werden es in Kürze erneut versuchen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Πάρα πολλά αιτήματα - η υπηρεσία καιρού μας ζήτησε να επιβραδύνουμε. Θα προσπαθήσουμε ξανά σύντομα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Too many requests — the weather service asked us to slow down. We'll try again shortly."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Demasiadas peticiones — el servicio meteorológico nos ha pedido que nos ralentizemos. Intentaremos de nuevo en breve."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liian monta pyyntöä — sääpalvelu pyysi meitä hidastumaan. Yritämme hetken kuluttua uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
