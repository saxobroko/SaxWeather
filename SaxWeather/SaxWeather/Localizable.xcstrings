    "Time-of-Day Rule swaps the background image to match the current lighting; Overlay Opacity dims the photo so text stays readable." : {
      "comment" : "Footer explaining time-of-day background options.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Time-of-Day Rule swaps the background image to match the current lighting; Overlay Opacity dims the photo so text stays readable."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Time-of-Day Rule swaps the background image to match the current lighting; Overlay Opacity dims the photo so text stays readable."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قاعدة وقت اليوم تبديل صورة الخلفية لمطابقة الإضاءة الحالية؛ يعيق التعتيم الصورة حتى يبقى النص مقروءا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Time-of-Day Rule swaps the background image to match the current lighting; Overlay Opacity dims the photo so text stays readable."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pravidlo pro časový limit dne přehodí obrázek na pozadí tak, aby odpovídal aktuálnímu osvětlení. Průhlednost překrytí ztmavuje obrázek, takže text zůstane čitelný."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regeltids-ombytter baggrundsbilledet til at matche den aktuelle belysning; Overlay-opacitet nedtoner billedet, så teksten forbliver læsbar."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Time-of-Day Regel tauscht das Hintergrundbild mit der aktuellen Beleuchtung ab; Overlay Deckkraft verdunkelt das Foto so dass Text lesbar bleibt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ο κανόνας ώρας ημέρας ανταλλάσσει την εικόνα φόντου για να ταιριάζει με τον τρέχοντα φωτισμό; Η διαφάνεια επικάλυψης σκοτεινιάζει τη φωτογραφία έτσι ώστε το κείμενο να παραμένει αναγνώσιμο."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La regla del día cambia la imagen de fondo para que coincida con la iluminación actual; la superposición atenúa la foto para que el texto siga siendo legible."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Päivän aikainen sääntö vaihtaa taustakuvan vastaamaan nykyistä valaistusta; Peitteen Läpinäkyvyys himmentää valoa, joten teksti pysyy luettavana."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La règle du temps de la journée permet d'échanger l'image d'arrière-plan pour correspondre à l'éclairage actuel; l'opacité de la superposition diminue la photo de sorte que le texte reste lisible."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Time-of-Day Rule swaps the background image to match the current lighting; Overlay Opacity dims the photo so text stays readable."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Time-of-Day Rule swaps the background image to match the current lighting; Overlay Opacity dims the photo so text stays readable."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Time-of-Day Rule swaps the background image to match the current lighting; Overlay Opacity dims the photo so text stays readable."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La regola del tempo del giorno scambia l'immagine di sfondo per abbinare l'illuminazione corrente; Overlay Opacity oscura la foto in modo che il testo rimanga leggibile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "日時のルール: 背景画像を現在の照明に一致させるように切り替えます。オーバーレイの不透明度が写真を暗くすると、テキストが読み取れる状態になります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Time-of-Day Rule swaps the background image to match the current lighting; Overlay Opacity dims the photo so text stays readable."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Time-of-Day Rule swapt de achtergrondafbeelding om te matchen met de huidige verlichting; Overlay ondoorzichtigheid dimt de foto zodat tekst leesbaar blijft."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tidspunkt over dags regler bytter bakgrunnsbildet for å matche den gjeldende belysningen; overleggets tetthet demmer bildet, slik at teksten forblir lesbar."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reguła czasowa zamienia obraz tła, aby dopasować się do bieżącego oświetlenia; Przezroczystość nakładki przyciemnia zdjęcie, więc tekst pozostaje czytelny."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A regra do dia troca a imagem de fundo para corresponder à iluminação atual; a Opacidade da sobreposição escurece a foto para que o texto permaneça legível."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A regra do dia troca a imagem de fundo para corresponder à iluminação atual; a Opacidade da sobreposição escurece a foto para que o texto permaneça legível."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regula de timp a zilei schimbă imaginea de fundal pentru a se potrivi luminii curente; Opacitatea suprapusă întunecă fotografia astfel încât textul rămâne lizibil."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Правило \"Время дня\" меняет фоновое изображение в соответствии с текущим освещением; Накладывание прозрачности затемняет фотографию, так что текст остается читаемым."
          }
        },
        "sq" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Time-of-Day Rule swaps the background image to match the current lighting; Overlay Opacity dims the photo so text stays readable."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Time-of-Day Rule swaps the background image to match the current lighting; Overlay Opacity dims the photo so text stays readable."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tid-av-dag regel byter bakgrundsbilden för att matcha den aktuella belysningen; Overlay Opacitet dämpar bilden så texten förblir läsbar."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Time-of-Day Rule swaps the background image to match the current lighting; Overlay Opacity dims the photo so text stays readable."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Правило «Час від дня» міняє фонове зображення, щоби відповідати поточному освітленню; Розмір відкладеного зображення зменшує яскравість зображення з можливістю його читання."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Time-of-Day Rule swaps the background image to match the current lighting; Overlay Opacity dims the photo so text stays readable."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "时间规则转换背景图像以匹配当前灯光； 覆盖照片的不透明度以使文字保持可读性。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Time-of-Day Rule swaps the background image to match the current lighting; Overlay Opacity dims the photo so text stays readable."
          }
        }
      }
    },
