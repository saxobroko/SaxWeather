          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La larghezza 0 rimuove completamente il bordo. Lo stile di contorno utilizza una corsa di pace 45%-o; altri stili usano il 20%."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Width 0は境界線を完全に削除します。アウトラインスタイルは45%-oペースストロークを使用します。他のスタイルは20%を使用します。"
