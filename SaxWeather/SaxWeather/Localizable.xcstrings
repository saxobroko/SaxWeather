          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaksWeer kan geen weer tonen voor uw huidige locatie. Schakel locatietoegang in bij Instellingen om GPS te gebruiken of vul coördinaten handmatig in."
          }
        },
        "no" : {
          "stringUnit" : {
