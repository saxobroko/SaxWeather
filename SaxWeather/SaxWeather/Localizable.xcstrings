    "error.locationDenied.message" : {
      "comment" : "Error alert message: location permission denied.",
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "SaxWeather can't show weather for your current location. Enable location access in Settings to use GPS, or enter coordinates manually."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "SaxWeather can't show weather for your current location. Enable location access in Settings to use GPS, or enter coordinates manually."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا يستطيع SaxWeather إظهار الطقس لموقعك الحالي. تمكين الوصول إلى الموقع في الإعدادات لاستخدام GPS أو إدخال الإحداثيات يدويا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "SaxWeather can't show weather for your current location. Enable location access in Settings to use GPS, or enter coordinates manually."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather nemůže zobrazit počasí pro vaši aktuální polohu. Povolte přístup k poloze v Nastavení pro použití GPS, nebo zadejte souřadnice ručně."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather kan ikke vise vejret for din aktuelle placering. Aktivér placeringsadgang i Indstillinger for at bruge GPS, eller indtast koordinater manuelt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather kann das Wetter für Ihren aktuellen Standort nicht anzeigen. Aktivieren Sie den Standortzugriff in den Einstellungen für die Verwendung von GPS oder geben Sie die Koordinaten manuell ein."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το SaxWeather δεν μπορεί να εμφανίσει τις καιρικές συνθήκες για την τρέχουσα τοποθεσία σας. Ενεργοποιήστε την πρόσβαση στην τοποθεσία από τις Ρυθμίσεις για να χρησιμοποιήσετε το GPS, ή εισάγετε συντεταγμένες χειροκίνητα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "SaxWeather can't show weather for your current location. Enable location access in Settings to use GPS, or enter coordinates manually."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather no puede mostrar el tiempo para su ubicación actual. Active el acceso a la ubicación en Ajustes para usar GPS o introduzca las coordenadas manualmente."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather ei voi näyttää säätä nykyiselle sijainnillesi. Ota sijaintikäyttö käyttöön Asetuksissa tai syötä koordinaatit manuaalisesti."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather ne peut pas afficher la météo pour votre position actuelle. Activez l'accès à la localisation dans les paramètres pour utiliser le GPS, ou entrez les coordonnées manuellement."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "SaxWeather can't show weather for your current location. Enable location access in Settings to use GPS, or enter coordinates manually."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "SaxWeather can't show weather for your current location. Enable location access in Settings to use GPS, or enter coordinates manually."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "SaxWeather can't show weather for your current location. Enable location access in Settings to use GPS, or enter coordinates manually."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather non può mostrare il meteo per la tua posizione attuale. Abilita l'accesso alla posizione nelle Impostazioni per usare GPS, o inserisci le coordinate manualmente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
