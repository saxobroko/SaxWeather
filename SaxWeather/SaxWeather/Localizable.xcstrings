    "Boost contrast, add text outlines, and use bold text for easier reading." : {
      "comment" : "Description of readability accessibility options.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Boost contrast, add text outlines, and use bold text for easier reading."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Boost contrast, add text outlines, and use bold text for easier reading."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بتعزيز التناقض، إضافة مخططات نصية، واستخدام نص عريض للقراءة أسهل."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Boost contrast, add text outlines, and use bold text for easier reading."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Naproti tomu zesílit přidávání textových popisů a používat tučný text pro snazší čtení."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Boost kontrast, tilføj tekst skitser, og brug fed tekst for lettere at læse."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erhöhen Sie den Kontrast, fügen Sie Textumrissen hinzu und verwenden Sie fette Texte zum einfacheren Lesen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ενισχύστε την αντίθεση, προσθέστε περιγράμματα κειμένου και χρησιμοποιήστε έντονο κείμενο για ευκολότερη ανάγνωση."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aumentar el contraste, añadir contornos de texto y utilizar texto en negrita para una lectura más fácil."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tehosta kontrasti, lisää tekstien ääriviivoja ja käytä rohkeaa tekstiä lukemisen helpottamiseksi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
