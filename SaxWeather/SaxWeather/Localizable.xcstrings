    "The free Default palette uses the shipped theme tokens. Themed palettes are cosmetic add-ons — buy the matching pack to unlock them." : {
      "comment" : "Footer on the palette picker section.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free Default palette uses the shipped theme tokens. Themed palettes are cosmetic add-ons — buy the matching pack to unlock them."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free Default palette uses the shipped theme tokens. Themed palettes are cosmetic add-ons — buy the matching pack to unlock them."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اللوحة الافتراضية المجانية تستخدم الرموز المميزة للموضوع المشحن. اللوحات المميزة هي إضافات تجميلية - اشتري الحزمة المطابقة لفتح تلك الرموز"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free Default palette uses the shipped theme tokens. Themed palettes are cosmetic add-ons — buy the matching pack to unlock them."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bezplatná výchozí paleta používá dodané tokeny šablony. Vážené palety jsou kosmetické doplňky — kupte odpovídající balíček pro jejich odemknutí."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Den gratis standard palet bruger det afsendte tema tokens. Themed paletter er kosmetiske tilføjelser - køb den matchende pakke for at låse dem op."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die kostenlose Standardpalette verwendet die versandten Theme-Token. Theme-Paletten sind kosmetische Zusätze — kaufen Sie das passende Paket, um sie freizuschalten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η δωρεάν Προεπιλεγμένη παλέτα χρησιμοποιεί τα διακριτικά θεμάτων που αποστέλλονται . Οι παλέτες θεμάτων είναι καλλυντικά πρόσθετα - αγοράστε το πακέτο που ταιριάζει για να τις ξεκλειδώσετε."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La paleta libre por defecto utiliza las fichas de tema enviadas. Las paletas temáticas son complementos cosméticos — compra el paquete correspondiente para desbloquearlos."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vapaa Oletuspaletti käyttää lähetettyjä teeman kuponkeja. Teemapaletit ovat kosmeettisia lisäosia – osta vastaava pakkaus avataksesi ne."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La palette par défaut gratuite utilise les jetons de thème expédiés. Les palettes à thème sont des compléments cosmétiques — achetez le pack correspondant pour les déverrouiller."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free Default palette uses the shipped theme tokens. Themed palettes are cosmetic add-ons — buy the matching pack to unlock them."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free Default palette uses the shipped theme tokens. Themed palettes are cosmetic add-ons — buy the matching pack to unlock them."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free Default palette uses the shipped theme tokens. Themed palettes are cosmetic add-ons — buy the matching pack to unlock them."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tavolozza predefinita gratuita utilizza i gettoni a tema spediti. Le tavolozze a tema sono componenti aggiuntivi cosmetici — compra il pacchetto corrispondente per sbloccarli."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無料のデフォルトパレットは出荷されたテーマトークンを使用します。テーマパレットは化粧品のアドオンです。マッチングパックを購入してロックを解除します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free Default palette uses the shipped theme tokens. Themed palettes are cosmetic add-ons — buy the matching pack to unlock them."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Het gratis standaard palet gebruikt de verzonden thematokens. Themed palettes zijn cosmetische add-ons - koop het bijpassende pakket om ze te ontgrendelen."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Med gratis standard-paletten bruker de pakkede temaetokene. Temerte paletter er kosmetiske tilleggsprogrammer – kjøp den samsvarende pakken for å låse opp dem."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Darmowa paleta domyślna używa wysłanych tokenów motywu. Styl palety są dodatkami kosmetycznymi — kup pasującą paczkę, aby ją odblokować."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A paleta padrão gratuita usa os tokens de tema enviados. Paletas temáticas são complementos cosméticos - compre o pacote correspondente para desbloqueá-los."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A paleta padrão gratuita usa os tokens de tema enviados. Paletas temáticas são complementos cosméticos - compre o pacote correspondente para desbloqueá-los."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paleta implicită gratuită folosește tokeni de temă expediați. Peretele sunt suplimente cosmetice - cumpărați pachetul potrivit pentru a le debloca."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Бесплатная палитра по умолчанию использует отправленные токены темы. Тематические палитры являются косметическими дополнениями — купите подходящий набор, чтобы разблокировать их."
          }
        },
        "sq" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free Default palette uses the shipped theme tokens. Themed palettes are cosmetic add-ons — buy the matching pack to unlock them."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free Default palette uses the shipped theme tokens. Themed palettes are cosmetic add-ons — buy the matching pack to unlock them."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Den fria Standard-paletten använder de levererade tema tokens. Tema paletter är kosmetiska tillägg — köpa matchande paket för att låsa upp dem."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free Default palette uses the shipped theme tokens. Themed palettes are cosmetic add-ons — buy the matching pack to unlock them."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Безкоштовна палітра за замовчуванням використовує маркери теми, які доставляються. Пальці з темами є косметичними додатками — купіть відповідний пакет, щоб розблокувати їх."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free Default palette uses the shipped theme tokens. Themed palettes are cosmetic add-ons — buy the matching pack to unlock them."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "默认调色板使用已发货的主题令牌。主题色板是装饰性附加组件 — 购买匹配包以解锁它们。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The free Default palette uses the shipped theme tokens. Themed palettes are cosmetic add-ons — buy the matching pack to unlock them."
          }
        }
      }
