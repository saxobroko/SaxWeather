    "error.locationUnavailable.message" : {
      "comment" : "Error alert message: current location could not be determined.",
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "We couldn't determine your current location. Make sure you're outdoors or near a window and try again."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "We couldn't determine your current location. Make sure you're outdoors or near a window and try again."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لم نتمكن من تحديد موقعك الحالي. تأكد من أنك في الخارج أو بالقرب من النافذة وحاول مرة أخرى."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "We couldn't determine your current location. Make sure you're outdoors or near a window and try again."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nemohli jsme zjistit vaši aktuální polohu. Ujistěte se, že jste venku nebo poblíž okna a zkuste to znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi kunne ikke bestemme din aktuelle placering. Sørg for, at du er udendørs eller i nærheden af et vindue, og prøv igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir konnten Ihren aktuellen Standort nicht ermitteln. Stellen Sie sicher, dass Sie draußen oder in der Nähe eines Fensters sind und versuchen Sie es erneut."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Δεν μπορούμε να προσδιορίσουμε την τρέχουσα τοποθεσία σας. Βεβαιωθείτε ότι είστε σε εξωτερικούς χώρους ή κοντά σε ένα παράθυρο και προσπαθήστε ξανά."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "We couldn't determine your current location. Make sure you're outdoors or near a window and try again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No pudimos determinar tu ubicación actual. Asegúrate de que estás al aire libre o cerca de una ventana e inténtalo de nuevo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emme pystyneet määrittämään nykyistä sijaintiasi. Varmista, että olet ulkona tai lähellä ikkunaa ja yritä uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous n'avons pas pu déterminer votre emplacement actuel. Assurez-vous que vous êtes à l'extérieur ou près d'une fenêtre et réessayez."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "We couldn't determine your current location. Make sure you're outdoors or near a window and try again."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "We couldn't determine your current location. Make sure you're outdoors or near a window and try again."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "We couldn't determine your current location. Make sure you're outdoors or near a window and try again."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Non siamo riusciti a determinare la tua posizione attuale. Assicurati di essere all'aperto o vicino a una finestra e riprova."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在地を特定できませんでした。屋外か窓の近くにいることを確認して、再度お試し下さい。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "We couldn't determine your current location. Make sure you're outdoors or near a window and try again."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We konden je huidige locatie niet bepalen. Zorg ervoor dat je buiten of dichtbij een raam bent en probeer het opnieuw."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi kunne ikke finne din nåværende posisjon. Kontroller at du er utendørs eller i nærheten av et vindu og prøv på nytt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nie mogliśmy określić Twojej bieżącej lokalizacji. Upewnij się, że jesteś na zewnątrz lub w pobliżu okna i spróbuj ponownie."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Não conseguimos determinar sua localização atual. Certifique-se de que você está ao ar livre ou perto de uma janela e tente novamente."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Não conseguimos determinar sua localização atual. Certifique-se de que você está ao ar livre ou perto de uma janela e tente novamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nu am putut determina locația ta curentă. Asigură-te că ești în aer liber sau lângă o fereastră și încearcă din nou."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Мы не смогли определить ваше текущее местоположение. Убедитесь, что вы находитесь на улице или рядом с окном и повторите попытку."
          }
        },
        "sq" : {
