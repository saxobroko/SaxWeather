    "Control the look of weather icons — colour style, filled vs outline symbols, and their size." : {
      "comment" : "Subtitle for icon appearance settings.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Control the look of weather icons — colour style, filled vs outline symbols, and their size."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Control the look of weather icons — colour style, filled vs outline symbols, and their size."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "التحكم في مظهر أيقونات الطقس - نمط الألوان، مملوءة في مقابل رموز المخطط، وحجمها."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Control the look of weather icons — colour style, filled vs outline symbols, and their size."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ovládat vzhled ikon počasí – barevný styl, vyplněný vs obrysy symbolů a jejich velikost."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Styr udseendet af vejr-ikoner - farvestil, fyldt vs omrids symboler og deres størrelse."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kontrollieren Sie das Aussehen der Wettersymbole — Farbstil, gefüllte vs umrissene Symbole und deren Größe."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ελέγξτε την εμφάνιση των εικονιδίων καιρού - χρώμα στυλ, γεμάτο vs περίγραμμα σύμβολα, και το μέγεθός τους."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Controla el aspecto de los iconos del tiempo: estilo de colores, símbolos rellenados vs contornos y su tamaño."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hallitse sääkuvakkeiden ulkoasua - värityyli, täytetyt vs ääriviivat symbolit ja niiden koko."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contrôlez l'apparence des icônes météo - style de couleur, symboles remplis vs contour et leur taille."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Control the look of weather icons — colour style, filled vs outline symbols, and their size."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Control the look of weather icons — colour style, filled vs outline symbols, and their size."
          }
        },
