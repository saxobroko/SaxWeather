    "Aggressive refresh uses more battery; Battery Saver throttles network calls." : {
      "comment" : "Footer explaining refresh-cadence options.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Aggressive refresh uses more battery; Battery Saver throttles network calls."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Aggressive refresh uses more battery; Battery Saver throttles network calls."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "التحديث العنيف يستخدم المزيد من البطارية؛ موفر البطارية مكالمات الشبكة."
          }
        },
        "ca" : {
          "stringUnit" : {
