    "Pinned days stay expanded in the forecast. Nicknames show in the daily header instead of the date." : {
      "comment" : "Footer explaining pinned days and nicknames.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Pinned days stay expanded in the forecast. Nicknames show in the daily header instead of the date."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Pinned days stay expanded in the forecast. Nicknames show in the daily header instead of the date."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الأيام المثبتة تبقى موسعة في التنبؤات. تظهر الأسماء في الترويسة اليومية بدلا من التاريخ."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Pinned days stay expanded in the forecast. Nicknames show in the daily header instead of the date."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Připnuté dny zůstávají rozšířeny v předpovědi. Přezdívky se zobrazují v záhlaví denního namísto data."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fastgjorte dage bliver udvidet i prognosen. Kaldenavne vises i den daglige overskrift i stedet for datoen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Angeheftete Tage bleiben in der Vorhersage erweitert. Nicknames werden in der täglichen Kopfzeile anstatt des Datums angezeigt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι καρφιτσωμένες ημέρες παραμονής επεκτάθηκαν στην πρόβλεψη. Τα ψευδώνυμα εμφανίζονται στην καθημερινή κεφαλίδα αντί για την ημερομηνία."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los días de anclaje se expanden en el previsto. Los apodos se muestran en la cabecera diaria en lugar de la fecha."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pinnattujen päivien määrä kasvaa ennusteessa. Lempinimet näkyvät päivittäisessä otsikossa päivän sijaan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les jours épinglés restent étendus dans la prévision. Les surnoms apparaissent dans l'en-tête quotidien au lieu de la date."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Pinned days stay expanded in the forecast. Nicknames show in the daily header instead of the date."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Pinned days stay expanded in the forecast. Nicknames show in the daily header instead of the date."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Pinned days stay expanded in the forecast. Nicknames show in the daily header instead of the date."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I giorni bloccati rimangono espansi nella previsione. I nick mostrano nell'intestazione giornaliera invece della data."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ピン留めされた日は予測で展開されます。ニックネームは日付の代わりにデイリーヘッダーに表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Pinned days stay expanded in the forecast. Nicknames show in the daily header instead of the date."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vastgezette dagen blijven uitgebreid in de voorspelling. Bijnamen worden weergegeven in de dagelijkse header in plaats van de datum."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Festede dager holder seg utvidet i prognosen. viser kallenavn i daglig topptekst i stedet for datoen."
          }
        },
        "pl" : {
