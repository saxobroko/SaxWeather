    "Tap the row to customise every card in the app: style, colour, glass, border, shadow, and tint, with a live preview." : {
      "comment" : "Subtitle for the card style entry.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tap the row to customise every card in the app: style, colour, glass, border, shadow, and tint, with a live preview."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tap the row to customise every card in the app: style, colour, glass, border, shadow, and tint, with a live preview."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انقر على الصف لتخصيص كل بطاقة في التطبيق: النمط واللون والزجاج والحدود والظل، مع معاينة مباشرة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tap the row to customise every card in the app: style, colour, glass, border, shadow, and tint, with a live preview."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klepnutím na řádek upravíte každou kartu v aplikaci: styl, barva, sklo, hranice, stín a malý, s živým náhledu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tryk på rækken for at tilpasse hvert kort i app'en: stil, farve, glas, kant, skygger og farvetone med en live forhåndsvisning."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe auf die Reihe, um jede Karte in der App anzupassen: Stil, Farbe, Glas, Rand, Schatten und Farbton mit Live-Vorschau."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Πατήστε τη γραμμή για να προσαρμόσετε κάθε κάρτα στην εφαρμογή: στυλ, χρώμα, γυαλί, περίγραμμα, σκιά και απόχρωση, με ζωντανή προεπισκόπηση."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca la fila para personalizar todas las cartas de la aplicación: estilo, color, vidrio, borde, sombra y color, con una vista previa en vivo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Napauta riviä muokataksesi jokaisen kortin sovelluksessa: tyyli, väri, lasi, raja, varjo ja sävy, jossa on live esikatselu."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tapotez sur la ligne pour personnaliser chaque carte de l'application : style, couleur, verre, bordure, ombre et teinte, avec un aperçu en direct."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tap the row to customise every card in the app: style, colour, glass, border, shadow, and tint, with a live preview."
          }
        },
