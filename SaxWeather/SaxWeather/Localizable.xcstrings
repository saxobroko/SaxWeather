          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Одноразовая покупка, которая автоматически открывает все косметические предметы в настоящее время и все будущие косметические средства, которые мы когда-либо перевозили."
          }
        },
        "sq" : {
