          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaxWeather nie może pokazywać pogody dla bieżącej lokalizacji. Włącz dostęp do lokalizacji w Ustawieniach, aby korzystać z GPS, lub wprowadź współrzędne ręcznie."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
