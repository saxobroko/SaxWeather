    "Export your current settings as a .saxtheme file. You can AirDrop it, save it to Files, or share it any other way." : {
      "comment" : "Description of the export action. Keep '.saxtheme'.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Export your current settings as a .saxtheme file. You can AirDrop it, save it to Files, or share it any other way."
          }
        },
        "an" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Export your current settings as a .saxtheme file. You can AirDrop it, save it to Files, or share it any other way."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بتصدير إعداداتك الحالية كملف.saxTheme. يمكنك أيردردب، أو حفظه في الملفات، أو مشاركته بأي طريقة أخرى."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Export your current settings as a .saxtheme file. You can AirDrop it, save it to Files, or share it any other way."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exportovat vaše aktuální nastavení jako soubor .saxtheme souboru. Můžete ho AirDrop, uložit do souborů nebo sdílet jiným způsobem."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eksporter dine aktuelle indstillinger som en .saxtheme-fil. Du kan AirDrop den, gemme den til filer eller dele den på anden måde."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exportieren Sie Ihre aktuellen Einstellungen als .saxtheme Datei. Sie können AirDrop verwenden, speichern Sie sie in Dateien oder teilen Sie sie auf andere Weise."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Εξαγάγετε τις τρέχουσες ρυθμίσεις σας ως αρχείο .saxtheme . Μπορείτε να το AirDrop, να το αποθηκεύσετε σε αρχεία ή να το μοιραστείτε με οποιονδήποτε άλλο τρόπο."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exportar su configuración actual como un archivo .saxtheme . Puede AirDrop, guardarlo en Archivos o compartirlo de cualquier otra forma."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vie nykyiset asetukset .saxtheme tiedosto. Voit AirDrop se, tallentaa sen tiedostoihin, tai jakaa sen millään muulla tavalla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exportez vos paramètres actuels en tant que fichier .saxthème. Vous pouvez l'AirDrop, l'enregistrer dans Fichiers, ou le partager d'une autre manière."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
