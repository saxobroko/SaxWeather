          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schakel meldingen in om regenstart- en stopmeldingen en ernstige weerwaarschuwingen voor uw locatie te ontvangen."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiver varsler for å motta regnstarte/stopp varsler og alvorlige værvarsler for din plassering."
